  a(class="site-header__logo" href="#trang_chu")
    img(src="assets/logo.webp" alt="Logo GO88")
  
  div(class="site-header__pseudo lg:hidden")

  div(class="site-header__container")
    nav#header_nav(class="site-header__nav")
      a(class="site-header__nav-item active" href="#trang_chu")
