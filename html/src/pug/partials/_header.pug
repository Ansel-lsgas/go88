mixin langSwitcher()
  div(class="btn--dropdown" data-value="vn")
    button(class="dropdown__trigger lang-switcher" type="button" aria-label="Chọn ngôn ngữ")
      div(class="dropdown__label")
        div(class="lang-switcher__flag-wrapper")
          div(class="lang-switcher__flag-inner")
            img(src="assets/lang_viet.webp" alt="Ngôn ngữ hiện tại")
        span(class="lang-switcher__label lg:hidden") Tiếng Việt
      span(class="dropdown__indicator")
        include ../icons/site_chevron.svg


    div(class="dropdown__list dropdown__list--at-right hidden")
      div(class="dropdown__item lang-switcher__option" data-value="vn")
        div(class="lang-switcher__option-flag")
          img(src="assets/lang_viet.webp" alt="Tiếng Việt")
        span(class="lang-switcher__option-label") Tiếng việt

      div(class="dropdown__item lang-switcher__option" data-value="en")
        div(class="lang-switcher__option-flag")
          img(src="assets/lang_eng.webp" alt="English")
        span(class="lang-switcher__option-label") English

header(class="site-header")
